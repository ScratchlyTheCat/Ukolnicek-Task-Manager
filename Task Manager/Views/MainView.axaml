<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Task_Manager.Views.MainView"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <Grid>
        <TabControl Margin="5">
            
            <TabItem Header="Správa úkolů">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="700">
                    <StackPanel Margin="15" Spacing="10" HorizontalAlignment="Stretch">
                        <TextBlock Text="Úkoly" FontSize="30"/>
                        
                        <TextBox x:Name="TasksNameBox" PlaceholderText="Zde zadejte svůj úkol" FontSize="18" HorizontalAlignment="Stretch"/>
                        <TextBlock Text="Termín dokončení:" FontSize="16"/>
                        <DatePicker x:Name="DueDatePicker" HorizontalAlignment="Stretch"/>
                        
                        <TextBlock Text="Priorita úkolu:" FontSize="16"/>
                        <ComboBox x:Name="PriorityComboBox" HorizontalAlignment="Stretch"/>
                        
                        <TextBlock Text="Barva štítku:" FontSize="16"/>
                        <ComboBox x:Name="ColorComboBox" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Blue"/>
                            <ComboBoxItem Content="Red"/>
                            <ComboBoxItem Content="Green"/>
                            <ComboBoxItem Content="Yellow"/>
                        </ComboBox>
                        
                        <Button Content="Vytvořit úkol" Click="VytvoritUkol_OnClick" Width="220" Background="DarkGreen" Foreground="White"/>
                        <Separator Height="10"/>

                        <TextBlock Text="Filtr úkolů:" FontSize="16" FontWeight="Bold"/>
                        <ComboBox x:Name="FilterComboBox" SelectionChanged="FilterComboBox_OnSelectionChanged" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Všechny úkoly"/>
                            <ComboBoxItem Content="Jen Aktivní (Nedokončené)"/>
                            <ComboBoxItem Content="Jen Hotové (Dokončené)"/>
                        </ComboBox>
                        <Separator Height="10"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Export do TXT" Click="ExportToTxt_OnClick" Width="140"/>
                            <Button Content="Načíst z TXT" Click="LoadFromTxt_OnClick" Width="140" Background="DarkBlue" Foreground="White"/>
                        </StackPanel>
                        
                        <Button Content="Přepnout Dark/Light mode" Click="ToggleTheme_OnClick" Width="220"/>
                        
                        <ListBox x:Name="TasksListBox" Height="200" HorizontalAlignment="Stretch"/>
                        <TextBlock x:Name="TasksInfoText" Text="Zatím tu nejsou žádné úkoly" FontSize="16" Foreground="Gray"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="Notifikace">
                <StackPanel Margin="20" Spacing="10" HorizontalAlignment="Stretch">
                    <TextBlock Text="Přehled Notifikací" FontSize="22" FontWeight="Bold"/>
                    <ListBox x:Name="NotificationsListBox" Height="600" HorizontalAlignment="Stretch" CornerRadius="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="16"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>
            
            <TabItem Header="Historie Aktivity">
                <StackPanel Margin="20" Spacing="10" HorizontalAlignment="Stretch">
                    <TextBlock Text="Historie operací" FontSize="22" FontWeight="Bold"/>
                    <ListBox x:Name="HistoryListBox" Height="600" HorizontalAlignment="Stretch" Background="#11000000" CornerRadius="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="16"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </TabItem>
            
        </TabControl>

        <Border x:Name="NotificationToast" 
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,50" Padding="15,12" 
                Background="#EE333333" CornerRadius="8" 
                Width="400" IsVisible="false"
                BoxShadow="0 4 12 0 #44000000">
            <Grid ColumnDefinitions="*, Auto">
                <TextBlock x:Name="NotificationToastText" 
                           Text="Example Message" 
                           Foreground="White" FontSize="14" FontWeight="Medium"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button Grid.Column="1" Content="✕" 
                        Background="Transparent" Foreground="DarkGray"
                        Padding="5,0" Margin="10,0,0,0"
                        Click="DismissNotification_OnClick" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>