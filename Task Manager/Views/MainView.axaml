<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Task_Manager.Views.MainView">
    
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Úkoly" FontSize="30"/>
        
        <TextBox
            x:Name="TasksNameBox"
            PlaceholderText="Zde zadejte svůj úkol"
            FontSize="18"
            
        />
        
        <Button
            Content="Vytvořit úkol"
            Click="VytvoritUkol_OnClick"
            Width="220"
        />
        
        <ListBox
            x:Name="TasksListBox"
            Height="250"
            Width="440"
        />
        
        <TextBlock
            x:Name="TasksInfoText"
            Text="Zatím tu nejsou žádné úkoly"
            FontSize="18"
        />
    </StackPanel>
    
</UserControl>